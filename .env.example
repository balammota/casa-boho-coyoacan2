# Copia a .env.local y rellena con tu proyecto Supabase (Settings → API).

NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase → Authentication → URL Configuration
# - Site URL (desarrollo): http://localhost:3000
# - Redirect URLs: añade al menos:
#   http://localhost:3000/auth/guest-callback
#   http://localhost:3000/auth/callback
#   (en producción, repite con tu dominio https://...)
# Si falta alguna URL, el signUp puede responder 422 por redirect_to inválido.

# Solo en servidor (Settings → API → service_role). Hace que /api/booking-data lea
# bloqueos y tarifas aunque RLS/GRANT del rol anon fallen. No uses NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Resend (https://resend.com) — envío de solicitudes de reserva desde /api/send-booking
RESEND_API_KEY=re_xxxx
# Remitente verificado en Resend (pruebas: "Casa Boho <onboarding@resend.dev>")
RESEND_FROM_EMAIL=Casa Boho <onboarding@resend.dev>
# Bandeja donde recibes las solicitudes y avisos (p. ej. cancelación por huésped)
BOOKING_INBOX_EMAIL=hello@casabohocoyoacan.com

# Enlace "Guest portal" en el pie + preparación de /guest (auth de huéspedes pendiente).
# NEXT_PUBLIC_ENABLE_GUEST_PORTAL=true

# Plantillas del arrendamiento (larga estancia), PDF para leer / firmar en persona.
# URLs públicas https (recomendado: sube los PDF a /public/contratos/ y usa
# https://tudominio.com/contratos/arrendamiento-es.pdf) o Google Drive con
# "Cualquiera con el enlace puede ver" y pega el enlace de compartir.
# En Drive, suele funcionar: https://drive.google.com/file/d/ID_DEL_ARCHIVO/view
# o para forzar descarga: https://drive.google.com/uc?export=download&id=ID_DEL_ARCHIVO
NEXT_PUBLIC_LONG_STAY_LEASE_TEMPLATE_ES_URL=
NEXT_PUBLIC_LONG_STAY_LEASE_TEMPLATE_EN_URL=

# Plantillas PDF del contrato (estancia corta), mismas reglas que larga estancia.
NEXT_PUBLIC_SHORT_STAY_LEASE_TEMPLATE_ES_URL=
NEXT_PUBLIC_SHORT_STAY_LEASE_TEMPLATE_EN_URL=

# Aplica supabase/migrations/009_guest_reservation_documents.sql para el bucket
# Storage "guest-documents" y la tabla guest_reservation_documents (subida desde el portal).

